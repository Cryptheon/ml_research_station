# ── API Keys ──────────────────────────────────────────────────────────────
# Semantic Scholar: free tier = 1 req/s; with key = 10 req/s
# Register at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# LLM backends (configure whichever you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Research Preferences ─────────────────────────────────────────────────
# Override any nested setting with __ separator
# PREFERENCES__ARXIV_CATEGORIES=["cs.LG","cs.AI","cs.CV","cs.CL","stat.ML"]
# PREFERENCES__KEYWORDS=["diffusion","transformer","RL"]
# PREFERENCES__DAYS_LOOKBACK=14
# PREFERENCES__MAX_RESULTS_PER_QUERY=200

# ── LLM Backend ─────────────────────────────────────────────────────────
# LLM__PROVIDER=anthropic      # anthropic | openai | ollama | vllm
# LLM__MODEL_NAME=claude-sonnet-4-6
# LLM__VLLM_BASE_URL=http://localhost:8000/v1
# LLM__OLLAMA_BASE_URL=http://localhost:11434

# ── Paths (defaults usually fine) ────────────────────────────────────────
# DATA_DIR=data
# PAPERS_DIR=data/papers
# DATABASE__SQLITE_PATH=data/db/research_station.db
# DATABASE__CHROMA_PATH=data/db/chroma
